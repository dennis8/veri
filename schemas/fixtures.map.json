{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://veri.dev/schemas/fixtures.map.json",
    "title": "Fixtures Map",
    "description": "Mapping of pytest fixtures and their dependencies",
    "type": "object",
    "properties": {
        "version": {
            "type": "string",
            "pattern": "^\\d+\\.\\d+\\.\\d+$",
            "description": "Schema version"
        },
        "generated_at": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 timestamp when this map was generated"
        },
        "fixtures": {
            "type": "object",
            "patternProperties": {
                ".*": {
                    "$ref": "#/$defs/fixture_info"
                }
            },
            "description": "Map from fixture name to fixture information"
        },
        "conftest_files": {
            "type": "array",
            "items": {
                "$ref": "#/$defs/conftest_info"
            },
            "description": "Information about conftest.py files"
        }
    },
    "required": [
        "version",
        "generated_at",
        "fixtures",
        "conftest_files"
    ],
    "additionalProperties": false,
    "$defs": {
        "fixture_info": {
            "type": "object",
            "properties": {
                "name": {
                    "type": "string",
                    "description": "Fixture name"
                },
                "scope": {
                    "type": "string",
                    "enum": [
                        "function",
                        "class",
                        "module",
                        "package",
                        "session"
                    ],
                    "description": "Fixture scope"
                },
                "defined_in": {
                    "type": "string",
                    "description": "Module where fixture is defined"
                },
                "line": {
                    "type": "integer",
                    "minimum": 1,
                    "description": "Line number where fixture is defined"
                },
                "dependencies": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "description": "Other fixtures this fixture depends on"
                },
                "autouse": {
                    "type": "boolean",
                    "description": "Whether this fixture is automatically used"
                },
                "params": {
                    "type": [
                        "array",
                        "null"
                    ],
                    "items": {
                        "type": "string"
                    },
                    "description": "Fixture parameters if parametrized"
                },
                "yield_fixture": {
                    "type": "boolean",
                    "description": "Whether this is a yield fixture (has teardown)"
                }
            },
            "required": [
                "name",
                "scope",
                "defined_in",
                "line",
                "dependencies",
                "autouse",
                "yield_fixture"
            ],
            "additionalProperties": false
        },
        "conftest_info": {
            "type": "object",
            "properties": {
                "path": {
                    "type": "string",
                    "description": "Path to conftest.py file"
                },
                "scope_path": {
                    "type": "string",
                    "description": "Directory path that this conftest affects"
                },
                "fixtures": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "description": "Fixtures defined in this conftest file"
                },
                "plugins": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "description": "Pytest plugins enabled in this conftest"
                },
                "digest": {
                    "type": "string",
                    "pattern": "^[a-f0-9]{64}$",
                    "description": "SHA-256 digest of conftest file content"
                }
            },
            "required": [
                "path",
                "scope_path",
                "fixtures",
                "plugins",
                "digest"
            ],
            "additionalProperties": false
        }
    }
}